# ─────────────────────────────────────────────────────────────────────────────
# Consilium Frontend – Environment Variables
# Copy this file to .env.local and set values for your environment.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the backend API, visible to the browser (must be VITE_ prefixed).
# - Development: leave empty → Vite dev-server proxy forwards /api/* to
#   API_TARGET (see below).  This avoids CORS entirely in local dev.
# - Production: set to your deployed API origin, e.g.
#   VITE_API_BASE_URL=https://api.consilium.example.com
VITE_API_BASE_URL=http://localhost:8000/api/v1/

# ── Vite dev-server proxy target (server-side only, NOT exposed to browser) ──
# Only used when running `npm run dev`.
# Must be the full base URL of the local backend (no trailing slash).
API_TARGET=http://localhost:8000/api/v1/
